# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                    # public read-only, used by frontend
SUPABASE_SERVICE_KEY=eyJ...                 # service role, used by scraper only

# LLM extraction fallback
ANTHROPIC_API_KEY=sk-ant-...
EXTRACTOR_MODEL=claude-haiku-4-5            # haiku for cost, sonnet for quality

# Discovery: vendor official Models APIs (each optional — source skips if absent)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...                      # GOOGLE_API_KEY also accepted
DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # Beijing-region keys

# Vercel revalidation
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Scraper config
SCRAPE_CONCURRENCY=4
SCRAPE_TIMEOUT_SECONDS=60
PLAYWRIGHT_HEADLESS=1
